{
  "name": "@novasamatech/host-chat",
  "type": "module",
  "version": "0.6.17",
  "private": "true",
  "description": "Host statement store chat integration",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/triangle-js-sdks.git"
  },
  "keywords": [
    "polkadot"
  ],
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "#/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./codec/message": {
      "types": "./dist/codec/message.d.ts",
      "default": "./dist/codec/message.js"
    },
    "./codec/attachment": {
      "types": "./dist/codec/attachment.d.ts",
      "default": "./dist/codec/attachment.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@novasamatech/scale": "0.6.17",
    "@novasamatech/statement-store": "0.6.17",
    "@novasamatech/storage-adapter": "0.6.17",
    "nanoid": "5.1.7",
    "neverthrow": "^8.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
