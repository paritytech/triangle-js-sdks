{
  "name": "@novasamatech/product-sdk",
  "type": "module",
  "version": "0.6.5",
  "description": "Polkadot product SDK: integrate and run your product inside Polkadot browser.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Polkadot-Community-Foundation/triangle-js-sdks.git"
  },
  "keywords": [
    "polkadot",
    "spektr",
    "dapp"
  ],
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@polkadot/extension-inject": "^0.62.6",
    "@polkadot-api/substrate-bindings": "^0.17.0",
    "@polkadot-api/json-rpc-provider": "^0.0.4",
    "@polkadot-api/json-rpc-provider-proxy": "^0.2.7",
    "@novasamatech/host-api": "0.6.5"
  },
  "scripts": {
    "rollup-dts": "api-extractor run --local && find dist -name \"*.d.ts\" ! -name \"_rollup.d.ts\" -delete && mv dist/_rollup.d.ts dist/index.d.ts && find dist -type d -empty -delete"
  },
  "publishConfig": {
    "access": "public"
  }
}
