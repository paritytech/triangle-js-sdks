{
  "name": "@novasamatech/scale",
  "type": "module",
  "version": "0.6.1",
  "description": "additional scale-ts bindings",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/novasamatech/spektr-sdk.git"
  },
  "keywords": [
    "polkadot"
  ],
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@polkadot-api/utils": "^0.2.0",
    "scale-ts": "1.6.1"
  },
  "scripts": {
    "rollup-dts": "api-extractor run --local && find dist -name \"*.d.ts\" ! -name \"_rollup.d.ts\" -delete && mv dist/_rollup.d.ts dist/index.d.ts && find dist -type d -empty -delete"
  },
  "publishConfig": {
    "access": "public"
  }
}
