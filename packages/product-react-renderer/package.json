{
  "name": "@novasamatech/product-react-renderer",
  "type": "module",
  "version": "0.8.4",
  "description": "React wrapper for custom renderer format from host-api-wrapper",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/triangle-js-sdks.git"
  },
