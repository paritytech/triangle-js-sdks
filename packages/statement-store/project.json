{
  "name": "@novasamatech/statement-store",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "cache": true,
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["tsc --build tsconfig.json", "node scripts/copy-wasm.mjs"],
        "parallel": false
      }
    }
  }
}
