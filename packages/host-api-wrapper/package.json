{
  "name": "@novasamatech/host-api-wrapper",
  "type": "module",
  "version": "0.8.5",
  "description": "Host API wrapper: integrate and run your product inside Polkadot browser.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/triangle-js-sdks.git"
  },
  "keywords": [
    "polkadot"
  ],
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "#/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@polkadot/extension-inject": "^0.63.1",
    "@polkadot-api/json-rpc-provider-proxy": "^0.4.0",
    "@polkadot-api/substrate-bindings": "^0.20.3",
    "@novasamatech/host-api": "0.8.5",
    "polkadot-api": ">=2",
    "neverthrow": "^8.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
